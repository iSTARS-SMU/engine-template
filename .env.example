# Copy to `.env` and adjust for your local pipeline test.
#
# Per-stage LLM mode:
#   real = call the provider using OPENAI_API_KEY
#   mock = keep the stage and tools real, but stub the LLM output
TRUSTCHAIN_RECON_LLM_MODE=mock
TRUSTCHAIN_WEAKNESS_GATHER_LLM_MODE=mock

# Only needed when one of the above modes is `real`.
OPENAI_API_KEY=

# Tool-side provider keys. Optional unless the tool/service itself needs them.
EXA_API_KEY=
NVD_API_KEY=
